{
  "name": "@simprints/simface-sdk",
  "version": "0.0.0",
  "simprints:releaseMajorVersion": "0",
  "description": "SimFace facial recognition SDK for web-based KYC workflows",
  "type": "module",
  "main": "dist/simface-sdk.umd.cjs",
  "module": "dist/simface-sdk.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/simface-sdk.js",
      "require": "./dist/simface-sdk.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "demo:dev": "node ./scripts/demo-dev.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0",
    "jsdom": "^25.0.0"
  }
}
